# MXID prod env template — copy to .env.prod and fill in. .env.prod is gitignored.
# Used by `make prod-docker-up` (docker compose --env-file deploy/compose/.env.prod up -d).

# Mode: standalone (bundled Postgres/Redis). For an EXTERNAL DB, drop the
# standalone file: COMPOSE_FILE=deploy/compose/docker-compose.yml
COMPOSE_FILE=deploy/compose/docker-compose.yml:deploy/compose/docker-compose.standalone.yml

# Released image tag — pin an explicit version, never `latest` (boot runs DB
# migrations, so a surprise image bump = a surprise migration).
MXID_TAG=v0.1.0

# Database / Redis — STRONG secrets. Release-mode validateSecrets rejects dev
# placeholders (12345 / 123456 / password / ...). Generate: openssl rand -hex 16
POSTGRES_USER=postgres
POSTGRES_DB=mxid
POSTGRES_PASSWORD=__CHANGE_ME__
REDIS_PASSWORD=__CHANGE_ME__

# CORS/CSRF allow-list — your portal/console origin(s), comma-separated.
MXID_SERVER_ALLOWED_ORIGINS=https://id.example.com

# Canonical external URLs — the OIDC issuer (`iss`) / SAML EntityID base / CAS
# root, plus portal and console. Third parties (Lark and other IdPs/SPs) redirect
# back to these. MUST be externally-reachable HTTPS (release mode rejects
# localhost). Single-domain deploy: set portal = issuer, console = issuer + /admin.
MXID_SERVER_ISSUER_URL=https://id.example.com
MXID_SERVER_PORTAL_URL=https://id.example.com
MXID_SERVER_CONSOLE_URL=https://id.example.com/admin

# TLS cert filenames under deploy/compose/cert/ (mounted into nginx).
CERT_FILE=fullchain.pem
KEY_FILE=privkey.pem

# OIDC signing-key master KEK — generate your own: openssl rand -base64 32
MXID_CRYPTO_KEY_ENCRYPTION_KEY=__CHANGE_ME__
