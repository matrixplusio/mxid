# Production web image: builds both SPAs and bakes them + the nginx prod config
# into an nginx image. Fully self-contained — prod pulls this image and runs it;
# no host-side pnpm build, no dist/ mounts, no repo checkout. (Dev still runs
# vite via Dockerfile.web.dev / air — that's a separate, host-friendly flow.)
#
# Built and pushed as ghcr.io/imkerbos/mxid-web by .github/workflows/release.yml.

# ---- Build stage: compile the SPAs ----
FROM node:22-alpine AS spabuild

# Declared so the shared release build-args (VERSION/COMMIT/BUILD_TIME) don't
# warn here. The web image doesn't embed them — the backend binary does.
ARG VERSION=dev
ARG COMMIT=none
ARG BUILD_TIME=unknown

RUN corepack enable

# Non-interactive: pnpm must never prompt to purge/reinstall in a build.
ENV CI=true

WORKDIR /app/web

# Install deps first (cached unless a package.json / lockfile changes). Copy
# every workspace manifest so pnpm can resolve the workspace graph.
COPY web/package.json web/pnpm-lock.yaml web/pnpm-workspace.yaml ./
COPY web/packages/shared/package.json ./packages/shared/
COPY web/apps/console/package.json ./apps/console/
COPY web/apps/portal/package.json ./apps/portal/
RUN pnpm install --frozen-lockfile

# Build all workspace packages → apps/{console,portal}/dist.
COPY web/ .
RUN pnpm -r build

# ---- Runtime stage: nginx serving the baked SPAs ----
FROM nginx:1.29-alpine

# Pull the latest patched OS packages on top of the base image — the nginx image
# lags the Alpine repo by a few package revisions, so this closes known-fixed
# CVEs (openssl / expat / libxml2 / nghttp2, …) without waiting for a base rebuild.
RUN apk upgrade --no-cache

# Config is a template: the nginx image's entrypoint runs envsubst on
# /etc/nginx/templates/*.template at startup. NGINX_ENVSUBST_FILTER restricts
# substitution to OUR vars only, so nginx's own $host / $uri / $remote_addr in
# the config are left untouched. Compose injects SERVER_NAME / CERT_FILE /
# KEY_FILE; the defaults below keep the image runnable standalone.
COPY deploy/nginx/prod.conf /etc/nginx/templates/default.conf.template
ENV NGINX_ENVSUBST_FILTER='SERVER_NAME|CERT_FILE|KEY_FILE'
ENV SERVER_NAME=_ \
    CERT_FILE=server.crt \
    KEY_FILE=server.key

# Static layout matches prod.conf: portal at root, console under /admin/ so the
# URL prefix maps 1:1 onto the filesystem (root, not alias).
COPY --from=spabuild /app/web/apps/portal/dist /var/www/mxid
COPY --from=spabuild /app/web/apps/console/dist /var/www/mxid/admin

EXPOSE 80 443
