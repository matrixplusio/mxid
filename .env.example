# MXID environment — copy and fill: cp .env.example .env
# .env holds real secrets and is gitignored. Keep THIS file secret-free.
#
# Layout:
#   [1] Secrets        — required everywhere
#   [2] Dev            — for `make dev` (air, host process) + dev compose
#   [3] Prod deploy    — the ONLY knobs you touch to deploy; nothing in the
#                        YAML config needs editing (env overrides win, and the
#                        rest is set in the console after first login)

# ─────────────────────────────────────────────────────────────────────────
# [1] Secrets (required)
# ─────────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mxid
POSTGRES_PORT=5432

REDIS_PASSWORD=changeme
REDIS_PORT=6379

# OIDC signing-key encryption master key (base64-encoded 32 random bytes).
# REQUIRED — the app refuses to start without it. Unique per deployment;
# rotating it invalidates all existing app signing keys.
#   openssl rand -base64 32
MXID_CRYPTO_KEY_ENCRYPTION_KEY=

# Audit hash-chain HMAC key (base64-encoded 32 random bytes). REQUIRED —
# the app refuses to start without it. Seals mxid_audit_entry.entry_hash so
# tampering with the audit log is detectable; unique per deployment,
# rotating it starts a new chain (old chain remains verifiable with the old
# key).
#   openssl rand -base64 32
MXID_CRYPTO_AUDIT_CHAIN_KEY=

# Audit anchor signing key (base64-encoded ed25519 seed). REQUIRED when
# audit anchoring is enabled (default) — the app refuses to start without
# it in release mode. Signs periodic checkpoints of the audit hash chain
# written to the anchor sink, so a full DB compromise that rewrites
# entry_hash end-to-end is still detectable against an out-of-band anchor.
#   openssl rand -base64 32
MXID_CRYPTO_AUDIT_ANCHOR_KEY=

# Enable/disable audit anchoring and where the signed anchors are appended.
# Disabling anchoring is an explicit opt-out (set to false) — otherwise
# release mode requires MXID_CRYPTO_AUDIT_ANCHOR_KEY above.
MXID_AUDIT_ANCHOR_ENABLED=true
MXID_AUDIT_ANCHOR_SINK_PATH=data/audit-anchors.log

# ─────────────────────────────────────────────────────────────────────────
# [2] Dev — `make dev` runs the backend as a host process (air) and reads
# these from .env. Docker dev/prod set them in compose, so they're dev-only.
# ─────────────────────────────────────────────────────────────────────────
MXID_DATABASE_HOST=host.docker.internal
MXID_DATABASE_PORT=5432
MXID_DATABASE_NAME=mxid
MXID_DATABASE_USER=postgres
MXID_DATABASE_PASSWORD=changeme
MXID_REDIS_HOST=host.docker.internal
MXID_REDIS_PORT=6379
MXID_REDIS_PASSWORD=changeme

# ─────────────────────────────────────────────────────────────────────────
# [3] Prod deploy — edit these, then run:  docker compose up -d
# ─────────────────────────────────────────────────────────────────────────

# Which compose files to load. Leave the first line for an EXTERNAL Postgres/
# Redis; use the second (uncomment, comment the first) for a self-contained
# stack with containerized Postgres + Redis + volumes.
COMPOSE_FILE=deploy/compose/docker-compose.yml
# COMPOSE_FILE=deploy/compose/docker-compose.yml:deploy/compose/docker-compose.standalone.yml

# Image version to run. REQUIRED in prod — pin an explicit released tag
# (e.g. v0.1.0). There is no `latest`: the app migrates the DB on boot, so a
# moving tag would mean a surprise migration.
MXID_TAG=v0.1.0

# CORS/CSRF allow-list — the one origin value that MUST be set at boot (it
# gates who can even reach the console). Comma-separate multiple origins.
MXID_SERVER_ALLOWED_ORIGINS=https://id.example.com

# Canonical external URLs — OIDC issuer (`iss`) / SAML EntityID base / CAS root,
# plus portal and console. Third parties (Lark and other IdPs/SPs) redirect back
# to these, so they MUST be your real externally-reachable HTTPS URLs (release
# mode rejects localhost). Single-domain deploy: portal = issuer, console =
# issuer + /admin. Without these the app boots on the id.example.com placeholder.
MXID_SERVER_ISSUER_URL=https://id.example.com
MXID_SERVER_PORTAL_URL=https://id.example.com
MXID_SERVER_CONSOLE_URL=https://id.example.com/admin

# nginx TLS — drop your cert + key in deploy/compose/cert/ and name them here.
SERVER_NAME=id.example.com
CERT_FILE=fullchain.pem
KEY_FILE=privkey.pem

# External DB/Redis hosts (only when NOT using the standalone compose file).
# Default to the host machine; point at your managed DB/Redis if elsewhere.
# MXID_DATABASE_HOST=host.docker.internal
# MXID_REDIS_HOST=host.docker.internal
